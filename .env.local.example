# ── Microsoft Graph API (enables OneDrive sync on Vercel) ──────
# Step-by-step setup:
# 1. Go to https://portal.azure.com → Azure Active Directory → App Registrations
# 2. Click "New Registration" → Name it "TEN Document Studio" → Register
# 3. Copy the "Application (client) ID" → AZURE_CLIENT_ID
# 4. Copy the "Directory (tenant) ID"   → AZURE_TENANT_ID
# 5. Go to Certificates & Secrets → New client secret → Copy value → AZURE_CLIENT_SECRET
# 6. Go to API Permissions → Add permission → Microsoft Graph → Application permissions
#    → Files.Read.All → Add → Grant admin consent
# 7. Your Microsoft 365 email                             → ONEDRIVE_USER_EMAIL

AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
ONEDRIVE_USER_EMAIL=malook@theexoticsnetwork.com

# Add all four to Vercel: Project Settings → Environment Variables → Production
