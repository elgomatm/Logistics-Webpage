# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build outputs (generated, never commit) ───────────────────────────────────
dist/                          # Vite compiled renderer
release/                       # electron-builder .dmg / .exe output
build/                         # PyInstaller temp workpath
out/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.spec                         # PyInstaller spec files (auto-generated)

# ── Compiled binary (built by BUILD.sh, not source) ──────────────────────────
resources/generate_report/generate_report
resources/generate_report/generate_report.exe

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── macOS / Windows ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/settings.json
*.tsbuildinfo
next-env.d.ts

# ── Vercel / legacy ───────────────────────────────────────────────────────────
.vercel
/.next/
